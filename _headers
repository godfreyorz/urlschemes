/*
  Access-Control-Allow-Origin: *
  Access-Control-Allow-Methods: GET,POST,PUT,PATCH,DELETE,OPTIONS
  Access-Control-Allow-Headers: Content-Type,Authorization

/admin/*
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-eval' https://unpkg.com; style-src 'self' 'unsafe-inline'; connect-src 'self' https://api.github.com https://api.netlify.com https://github.com; img-src 'self' data: https://avatars.githubusercontent.com;

/sources.json
  Cache-Control: public, max-age=60, s-maxage=300
